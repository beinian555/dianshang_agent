# ── 运行模式 ──
# memory = 内存存储（无需数据库，重启后数据丢失）
# postgres = PostgreSQL 持久化（需先启动数据库）
STORE_BACKEND=postgres

# PostgreSQL 连接（STORE_BACKEND=postgres 时必填）
# Docker Compose 用 db（service 名），本地开发用 localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecommerce_growth

# ── LLM 配置 ──
# mock = 模拟数据，不调用真实 API
# real = 调用真实 LLM
LLM_PROVIDER=real

# DeepSeek API Key → https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek Base URL（OpenAI 兼容接口，无需改动）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 模型：deepseek-chat (V3，推荐) / deepseek-reasoner (R1，推理强)
LLM_MODEL=deepseek-chat

# 超时秒数（复杂分析可能较长）
LLM_TIMEOUT=60

# ── 服务 ──
APP_PORT=8000
DEBUG=false
